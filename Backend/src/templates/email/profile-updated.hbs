{{! templates/email/profile-updated.hbs }}
    <div class="profile-updated-container">
      <h1 style="color: #3b82f6;">📝 Perfil Actualizado</h1>
      <p>Hola <strong>{{firstName}}</strong>,</p>
      <p>Tu perfil ha sido actualizado exitosamente.</p>
      
      {{#if changes}}
      <div style="background: #f0f9ff; padding: 20px; border-radius: 8px; margin: 20px 0;">
        <h3 style="color: #0369a1; margin-top: 0;">Cambios realizados:</h3>
        <ul>
          {{#each changes}}
          <li><strong>{{@key}}:</strong> {{this}}</li>
          {{/each}}
        </ul>
      </div>
      {{/if}}
      
      <p>Si no realizaste estos cambios, contacta a soporte inmediatamente.</p>
      
      {{> button text="Ver mi perfil" url=(absoluteUrl "/profile") }}
    </div>