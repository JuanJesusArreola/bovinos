{{! templates/email/password-reset.hbs }}
  {{#*inline "content"}}
    <div class="password-reset-container">
      <h1 style="color: #dc2626;">Restablece tu contraseña</h1>
      <p>Hola <strong>{{firstName}}</strong>,</p>
      <p>Recibimos una solicitud para restablecer tu contraseña.</p>
      
      {{> button text="Restablecer contraseña" url=resetLink }}
      
      <p style="font-size: 12px; color: #666;">
        <small>Este enlace expira en 1 hora por seguridad.</small>
      </p>
      <p style="font-size: 12px; color: #666;">
        <small>Si no solicitaste este cambio, puedes ignorar este email.</small>
      </p>
    </div>
  {{/inline}}