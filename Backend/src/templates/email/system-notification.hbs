{{! templates/email/system-notification.hbs }}
  {{#*inline "content"}}
    <div class="system-notification-container">
      <h1 style="color: #6b7280;">🔔 {{title}}</h1>
      <p>Hola <strong>{{firstName}}</strong>,</p>
      
      <div style="background: #f3f4f6; padding: 20px; border-radius: 8px; margin: 20px 0;">
        <p style="margin: 0;">{{message}}</p>
        {{#if details}}
        <p style="margin: 10px 0 0 0; color: #4b5563;">{{details}}</p>
        {{/if}}
      </div>
      
      {{#if actionUrl}}
        {{> button text=actionText url=actionUrl }}
      {{/if}}
    </div>
  {{/inline}}