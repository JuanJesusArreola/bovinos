{{! templates/email/partials/button.hbs }}
<table style="margin: 30px auto;" cellpadding="0" cellspacing="0">
  <tr>
    <td style="border-radius: 8px; background: linear-gradient(135deg, #16a34a 0%, #059669 100%);">
      <a href="{{url}}" 
         style="display: inline-block; padding: 15px 30px; color: white; text-decoration: none; font-weight: bold; font-size: 16px; border-radius: 8px;">
        {{text}}
      </a>
    </td>
  </tr>
</table>