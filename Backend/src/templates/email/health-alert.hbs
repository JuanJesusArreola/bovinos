{{! templates/email/health-alert.hbs }}
  {{#*inline "content"}}
    <div class="health-alert-container">
      <h1 style="color: #dc2626;">🚨 ALERTA DE SALUD</h1>
      <p>Estimado/a <strong>{{ownerName}}</strong>,</p>
      
      <div style="background: #fee2e2; padding: 20px; border-radius: 8px; margin: 20px 0; border-left: 4px solid #dc2626;">
        <h3 style="color: #991b1b; margin-top: 0;">Bovino {{bovineEarTag}} {{#if bovineName}}({{bovineName}}){{/if}}</h3>
        <p><strong>Estado:</strong> {{healthStatus}}</p>
        <p><strong>Severidad:</strong> 
          {{#ifEquals severity 'CRITICAL'}}🔴 Crítica{{/ifEquals}}
          {{#ifEquals severity 'HIGH'}}🟠 Alta{{/ifEquals}}
          {{#ifEquals severity 'MEDIUM'}}🟡 Media{{/ifEquals}}
          {{#ifEquals severity 'LOW'}}🟢 Baja{{/ifEquals}}
        </p>
        {{#if symptomsList}}
        <p><strong>Síntomas:</strong> {{symptomsList}}</p>
        {{/if}}
        <p><strong>Ubicación:</strong> {{location}}</p>
        <p><strong>Reportado:</strong> {{formatDate reportedAt}} a las {{formatTime reportedAt}}</p>
      </div>
      
      {{> button text="Ver detalles" url=(absoluteUrl (concat "/bovines/" bovineEarTag)) }}
    </div>
  {{/inline}}