{{! templates/email/account-locked.hbs }}

    <div class="account-locked-container">
      <h1 style="color: #dc2626;">🔒 Cuenta Bloqueada</h1>
      <p>Hola <strong>{{firstName}}</strong>,</p>
      
      <div style="background: #fee2e2; padding: 20px; border-radius: 8px; margin: 20px 0;">
        <p style="margin: 0;">Tu cuenta ha sido bloqueada por razones de seguridad.</p>
        {{#if reason}}
        <p style="margin: 10px 0 0 0;"><strong>Razón:</strong> {{reason}}</p>
        {{/if}}
      </div>
      
      <p>Por favor, contacta al administrador del sistema para restablecer tu acceso.</p>
      
      {{> button text="Contactar soporte" url="mailto:soporte@ganadero-ujat.com" }}
    </div>
