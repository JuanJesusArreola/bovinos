{
  "name": "bovino-ujat-backend",
  "version": "1.0.0",
  "description": "Backend para Sistema de Gestión Ganadera - UJAT",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "nodemon src/index.ts",
    "build": "tsc",
    "build:watch": "tsc -w",
    "clean": "rimraf dist",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "test": "jest",
    "db:create": "createdb bovino_ujat_db",
    "db:reset": "ts-node scripts/database.ts reset",
    "db": "ts-node scripts/database.ts",
    "db:status": "ts-node scripts/database.ts status",
    "db:info": "ts-node scripts/database.ts info",
    "db:sync": "ts-node scripts/database.ts sync",
    "db:sync:force": "ts-node scripts/database.ts sync --force",
    "db:sync:alter": "ts-node scripts/database.ts sync --alter",
    "db:init": "ts-node scripts/database.ts init",
    "db:test": "ts-node scripts/database.ts test",
    "migration:create": "ts-node scripts/database.ts migration create",
    "migration:up": "ts-node scripts/database.ts migration up",
    "migration:down": "ts-node scripts/database.ts migration down",
    "migration:status": "ts-node scripts/database.ts migration status",
    "backup:full": "ts-node scripts/database.ts backup full",
    "backup:schema": "ts-node scripts/database.ts backup schema",
    "backup:data": "ts-node scripts/database.ts backup data",
    "backup:list": "ts-node scripts/database.ts backup list",
    "backup:clean": "ts-node scripts/database.ts backup clean",
    "backup:stats": "ts-node scripts/database.ts backup stats"
  },
  "keywords": [
    "nodejs",
    "express",
    "typescript",
    "postgresql",
    "sequelize",
    "ganado",
    "bovinos",
    "ujat",
    "tabasco"
  ],
  "author": "UJAT - Universidad Juárez Autónoma de Tabasco",
  "license": "MIT",
  "dependencies": {
    "@types/nodemailer": "^7.0.2",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.1.5",
    "express-slow-down": "^2.0.1",
    "express-validator": "^7.2.1",
    "helmet": "^7.1.0",
    "hpp": "^0.2.3",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "moment": "^2.29.4",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^7.0.9",
    "pg": "^8.11.3",
    "sequelize": "^6.35.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.8",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.19.9",
    "@types/node-cron": "^3.0.11",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^6.12.0",
    "@typescript-eslint/parser": "^6.12.0",
    "eslint": "^8.54.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.10",
    "rimraf": "^5.0.10",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tu-usuario/bovino-ujat-backend.git"
  }
}
