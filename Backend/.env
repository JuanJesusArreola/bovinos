# ============================================================================
# CONFIGURACIÓN GENERAL DEL SERVIDOR
# ============================================================================
NODE_ENV=development
PORT=5000
API_VERSION=v1
BASE_URL=http://localhost:5000

# ============================================================================
# CONFIGURACIÓN DE BASE DE DATOS POSTGRESQL
# ============================================================================
# Datos de conexión principal
DB_HOST=localhost
DB_PORT=5432
DB_NAME=bovino_system_db
DB_USERNAME=postgres
DB_PASSWORD=Eminem1710

# URL de conexión completa (alternativa)
DATABASE_URL=postgresql://postgres:Eminem1710@localhost:5432/bovino_system_db


# Configuraciones adicionales de la BD
DB_DIALECT=postgres
DB_LOGGING=true
DB_POOL_MAX=20
DB_POOL_MIN=5
DB_POOL_ACQUIRE=30000
DB_POOL_IDLE=10000

# ============================================================================
# CONFIGURACIÓN JWT Y AUTENTICACIÓN
# ============================================================================
# Secreto para firmar tokens JWT (cambiar en producción)
JWT_SECRET=bovino_ujat_super_secret_key_2024_development_secure_123
JWT_REFRESH_SECRET=bovino_ujat_refresh_super_secret_key_2024_development_secure_456
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d
JWT_ACCESS_SECRET=bovino_ujat_super_secret_key_2024_development_secure_123

# Secreto para cookies de sesión
SESSION_SECRET=bovino_ujat_session_secret_key_2024_development_secure_789

# ============================================================================
# CONFIGURACIÓN DE CORS
# ============================================================================
# Orígenes permitidos (frontend)
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ============================================================================
# CONFIGURACIÓN DE ARCHIVOS Y UPLOADS
# ============================================================================
# Límite de tamaño para archivos (en MB)
MAX_FILE_SIZE=10
UPLOAD_DIR=uploads/
TEMP_DIR=temp/

# Tipos de archivos permitidos
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/gif,image/webp
ALLOWED_DOCUMENT_TYPES=application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document

# ============================================================================
# CONFIGURACIÓN DE GEOLOCALIZACIÓN Y MAPAS
# ============================================================================
# Configuraciones específicas para México/Tabasco
DEFAULT_LATITUDE=17.989058
DEFAULT_LONGITUDE=-92.935139
DEFAULT_LOCATION=Villahermosa, Tabasco, México

# Radio de búsqueda en kilómetros
GEOFENCE_RADIUS=50
MAX_LOCATION_AGE=300000

# API Keys para servicios de mapas (agregar tus claves)
MAPBOX_API_KEY=your_mapbox_api_key_here
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ============================================================================
# CONFIGURACIÓN DE EMAIL/NOTIFICACIONES
# ============================================================================
# Configuración SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=arreolajimenezjuanjesus@gmail.com
SMTP_PASSWORD=segc dqgg ilbj niux
FROM_NAME=Sistema Ganadero UJAT
FROM_EMAIL=arreolajimenezjuanjesus@gmail.com

# ============================================================================
# CONFIGURACIÓN DE SEGURIDAD
# ============================================================================
# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Encriptación adicional
ENCRYPTION_KEY=your_32_char_encryption_key_here123
SALT_ROUNDS=12

# ============================================================================
# CONFIGURACIÓN DE LOGGING
# ============================================================================
LOG_LEVEL=info
LOG_DIR=logs/
LOG_MAX_SIZE=10m
LOG_MAX_FILES=5
LOG_DATE_PATTERN=YYYY-MM-DD

# ============================================================================
# CONFIGURACIÓN DE CACHE
# ============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_PREFIX=ganadero:

# ============================================================================
# CONFIGURACIÓN ESPECÍFICA DEL NEGOCIO
# ============================================================================
# Configuraciones para el manejo de ganado
MIN_VACCINATION_INTERVAL_DAYS=30
MAX_GESTATION_PERIOD_DAYS=285
ALERT_THRESHOLD_DAYS=7

# Configuraciones de inventario
LOW_STOCK_THRESHOLD=10
MEDICATION_EXPIRY_ALERT_DAYS=30

# ============================================================================
# CONFIGURACIÓN DE DESARROLLO/TESTING
# ============================================================================
# Variables para testing
TEST_DB_NAME=bovino_ujat_db_test
ENABLE_MOCK_DATA=true
DEBUG_MODE=true

# Variables para desarrollo
HOT_RELOAD=true
API_DOCS_ENABLED=true
CORS_DEBUG=true

# ============================================================================
